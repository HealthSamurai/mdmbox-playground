# Aidbox
AIDBOX_URL=http://localhost:8888
AIDBOX_AUTH=Basic YmFzaWM6c2VjcmV0

# MDMbox
MDMBOX_URL=http://localhost:3003
# Authorization header injected by the server proxy on every MDMbox request.
# Leave unset when MDMbox runs with auth disabled (BOX_SECURITY_DEV_MODE=true).
# e.g. Basic <base64(client-id:secret)> — root:root => Basic cm9vdDpyb290
# MDMBOX_AUTH=Basic cm9vdDpyb290

# Server
PORT=3000
